# =============================================================================
# Jerumed Nexus — production environment
# Copy to `.env` and fill in real values:  cp .env.example .env
# NEVER commit the real `.env` (it is gitignored).
# =============================================================================

# ---- PostgreSQL (used by the `db` service) ---------------------------------
POSTGRES_USER=jerunexus
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=jerunexus

# ---- App: database connection ----------------------------------------------
# Host is the compose service name `db` on the internal network, port 5432.
DATABASE_URL=postgresql://jerunexus:CHANGE_ME_strong_db_password@db:5432/jerunexus?schema=public

# ---- App: auth -------------------------------------------------------------
# Generate with:  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_long_random_secret

# ---- App: email (Resend) ---------------------------------------------------
# Rotate this key before going live — the previous one was shared in chat.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Jerumed Nexus <noreply@jerumed-nexus.ch>

# ---- App: public URL (used in verification links) --------------------------
# Must be the HTTPS domain users hit through Caddy.
APP_URL=https://your-domain.example

# ---- Caddy: auto-HTTPS entrypoint ------------------------------------------
# The public hostname Caddy serves. Must be a real domain with DNS pointing at
# this server for Let's Encrypt to issue a cert. For local testing use
# `localhost` (Caddy then uses its own internal CA / self-signed cert).
SITE_ADDRESS=your-domain.example
# Contact email for Let's Encrypt (renewal/expiry notices).
ACME_EMAIL=you@example.com
